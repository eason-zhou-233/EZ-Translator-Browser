{
  "manifest_version": 3,
  "name": "EZ Translator 翻译神器",
  "version": "1.0.0",
  "description": "Translate webpages, selected text, and free-form input with Google Translate or OpenAI-compatible APIs.",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://translate.googleapis.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "16": "icons/icon_2.png",
    "32": "icons/icon_2.png",
    "48": "icons/icon_2.png",
    "128": "icons/icon_2.png"
  },
  "action": {
    "default_title": "EZ Translator 翻译神器",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon_2.png",
      "32": "icons/icon_2.png",
      "48": "icons/icon_2.png",
      "128": "icons/icon_2.png"
    }
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content_script.js",
        "lang_detect.js"
      ],
      "run_at": "document_end"
    }
  ]
}